# Git
.git
.gitignore

# Node
frontend/node_modules
frontend/.vite

# Python
backend/.venv
backend/__pycache__
backend/.pytest_cache
backend/.ruff_cache
**/__pycache__
**/*.pyc

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Data (mounted as volume)
data/

# Docs and fixtures (not needed in image)
docs/
fixtures/
frontend/mockups/

# Tests (not needed in production image)
tests/
backend/tests/

# Dev files
*.md
# Re-include legal manifests the runtime image must carry. Adding them
# back here (after the ``*.md`` blanket) restores them to the build
# context so the Dockerfile's ``COPY LICENSE`` / ``COPY NOTICE`` /
# ``COPY THIRD-PARTY-LICENSES.md`` all resolve. AGPL-3.0 + bundled
# third-party attribution have to travel with every deployment per the
# legal-readiness paperwork in PR #181 — and the build silently broke
# for THIRD-PARTY-LICENSES.md when that file landed without a matching
# ``.dockerignore`` exemption (caught by the v0.2.0 release run).
!THIRD-PARTY-LICENSES.md
.env
.env.*

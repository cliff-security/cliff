{
  "name": "frontend",
  "private": true,
  "version": "0.2.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006 --config-dir ../.storybook",
    "build-storybook": "storybook build --config-dir ../.storybook",
    "generate:types": "openapi-typescript http://localhost:8000/openapi.json -o src/api/types.ts",
    "generate:types:snapshot": "openapi-typescript ../backend/tests/api/openapi_snapshot.json -o src/api/types.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.2",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.15",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
